---
import Base from '../layouts/Base.astro';
import '../styles/global.css';
---

<Base
  title="Ainjiner — AI Engineering for Education & Society"
  description="Open-source AI tools built in Indonesia. Seeking donors, research partners, and institutional funding to develop 2USE, We Will Shine, and AI Lab."
>
  <!-- NAV -->
  <header class="sticky top-0 z-50 border-b border-[#27272a] bg-[#09090b]/80 backdrop-blur-xl">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 h-14 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5 font-semibold text-sm tracking-tight min-h-[44px]">
        <svg width="26" height="26" viewBox="0 0 64 64" fill="none">
          <rect width="64" height="64" rx="14" fill="#8b5cf6"/>
          <text x="32" y="45" font-family="Georgia,serif" font-size="36" font-weight="700" fill="white" text-anchor="middle">A</text>
        </svg>
        <span class="text-[#fafafa]">ainjiner</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden sm:flex items-center gap-1">
        <a href="#projects" class="px-3 py-2 text-sm text-[#a1a1aa] hover:text-[#fafafa] rounded-md hover:bg-[#18181b] transition-colors min-h-[44px] inline-flex items-center">Projects</a>
        <a href="#impact"   class="px-3 py-2 text-sm text-[#a1a1aa] hover:text-[#fafafa] rounded-md hover:bg-[#18181b] transition-colors min-h-[44px] inline-flex items-center">Impact</a>
        <a href="#research" class="px-3 py-2 text-sm text-[#a1a1aa] hover:text-[#fafafa] rounded-md hover:bg-[#18181b] transition-colors min-h-[44px] inline-flex items-center">Research</a>
        <a href="#support"  class="px-3 py-2 text-sm text-[#a1a1aa] hover:text-[#fafafa] rounded-md hover:bg-[#18181b] transition-colors min-h-[44px] inline-flex items-center">Support</a>
        <a href="mailto:hello@ainjiner.ai"
           class="ml-2 flex items-center gap-1.5 px-3 py-2 text-sm font-medium text-white bg-[#8b5cf6] rounded-lg hover:bg-[#7c3aed] transition-colors min-h-[44px]">
          Contact Us
        </a>
      </nav>

      <!-- Mobile: Contact CTA + hamburger -->
      <div class="flex items-center gap-2 sm:hidden">
        <a href="mailto:hello@ainjiner.ai"
           class="flex items-center px-3 py-2 text-xs font-medium text-white bg-[#8b5cf6] rounded-lg hover:bg-[#7c3aed] transition-colors min-h-[44px]">
          Contact
        </a>
        <button
          data-nav-toggle
          aria-expanded="false"
          aria-label="Toggle menu"
          class="flex items-center justify-center w-11 h-11 rounded-md text-[#a1a1aa] hover:text-[#fafafa] hover:bg-[#18181b] transition-colors"
        >
          <!-- Hamburger icon -->
          <svg data-icon-open width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
          <!-- Close icon -->
          <svg data-icon-close class="hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu drawer -->
    <nav
      data-nav-menu
      class="hidden sm:hidden border-t border-[#27272a] bg-[#09090b] px-4 pb-4"
    >
      <div class="flex flex-col pt-2 gap-1">
        <a href="#projects" data-nav-link class="px-3 py-3 text-sm text-[#a1a1aa] hover:text-[#fafafa] rounded-md hover:bg-[#18181b] transition-colors min-h-[44px] flex items-center">Projects</a>
        <a href="#impact"   data-nav-link class="px-3 py-3 text-sm text-[#a1a1aa] hover:text-[#fafafa] rounded-md hover:bg-[#18181b] transition-colors min-h-[44px] flex items-center">Impact</a>
        <a href="#research" data-nav-link class="px-3 py-3 text-sm text-[#a1a1aa] hover:text-[#fafafa] rounded-md hover:bg-[#18181b] transition-colors min-h-[44px] flex items-center">Research</a>
        <a href="#support"  data-nav-link class="px-3 py-3 text-sm text-[#a1a1aa] hover:text-[#fafafa] rounded-md hover:bg-[#18181b] transition-colors min-h-[44px] flex items-center">Support</a>
      </div>
    </nav>
  </header>

  <!-- HERO -->
  <section class="relative overflow-hidden px-4 sm:px-6 pt-20 pb-16 sm:pt-24 sm:pb-20 text-center">
    <!-- Glow blob — capped to viewport width -->
    <div class="pointer-events-none absolute inset-0 flex items-start justify-center overflow-hidden">
      <div class="mt-[-80px] h-[400px] sm:h-[500px] w-full max-w-[900px] rounded-full bg-[#8b5cf6]/10 blur-[100px] sm:blur-[130px]"></div>
    </div>
    <!-- Dot grid — slightly larger on mobile to avoid noise -->
    <div class="pointer-events-none absolute inset-0 opacity-[0.02]"
      style="background-image: radial-gradient(#fafafa 1px, transparent 1px); background-size: 32px 32px;"></div>

    <div class="relative mx-auto max-w-3xl">
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#8b5cf6]/25 bg-[#8b5cf6]/10 px-4 py-1.5 text-xs font-medium text-[#a78bfa]">
        <span class="h-1.5 w-1.5 rounded-full bg-[#a78bfa] animate-pulse"></span>
        Seeking Donors · Research Partners · Institutional Funding
      </div>

      <h1 class="mb-5 font-bold tracking-tight text-[#fafafa] leading-[1.08]" style="font-size: clamp(2rem, 5vw, 3.5rem);">
        Open-source AI tools
        <span class="bg-gradient-to-br from-[#a78bfa] via-[#818cf8] to-[#60a5fa] bg-clip-text text-transparent block sm:inline">
          built for Indonesia
        </span>
      </h1>

      <p class="mx-auto mb-4 max-w-2xl text-sm sm:text-base text-[#a1a1aa] leading-relaxed">
        We build free, open-source AI infrastructure and education tools for underserved communities.
        Three active projects. Real students and educators as users. Zero external funding — yet.
      </p>
      <p class="mx-auto mb-8 sm:mb-9 max-w-xl text-sm text-[#71717a] leading-relaxed">
        Your support — whether a donation, a research grant, or a partnership — directly accelerates
        tools that help Indonesian students think critically, find their path, and access AI without dependency.
      </p>

      <!-- CTA buttons — stacked on mobile, row on sm+ -->
      <div class="flex flex-col sm:flex-row sm:flex-wrap items-center justify-center gap-3 mb-14 sm:mb-16">
        <a href="#support"
           class="w-full sm:w-auto inline-flex items-center justify-center gap-2 rounded-xl bg-[#8b5cf6] px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-[#8b5cf6]/25 hover:bg-[#7c3aed] transition-all hover:-translate-y-px min-h-[44px]">
          Support This Work
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="#research"
           class="w-full sm:w-auto inline-flex items-center justify-center gap-2 rounded-xl border border-[#27272a] bg-[#18181b] px-6 py-3 text-sm font-medium text-[#a1a1aa] hover:text-[#fafafa] hover:border-[#3f3f46] transition-all hover:-translate-y-px min-h-[44px]">
          Research &amp; Grants
        </a>
        <a href="#projects"
           class="w-full sm:w-auto inline-flex items-center justify-center gap-2 rounded-xl border border-[#27272a] bg-transparent px-6 py-3 text-sm font-medium text-[#71717a] hover:text-[#a1a1aa] hover:border-[#3f3f46] transition-all min-h-[44px]">
          Explore Projects
        </a>
      </div>

      <!-- Trust bar -->
      <div class="flex flex-wrap items-center justify-center gap-x-8 sm:gap-x-10 gap-y-4">
        <div class="text-center">
          <div class="text-2xl font-bold text-[#fafafa] tracking-tight">4</div>
          <div class="text-xs text-[#71717a] mt-0.5">Active Projects</div>
        </div>
        <div class="h-8 w-px bg-[#27272a] hidden sm:block"></div>
        <div class="text-center">
          <div class="text-2xl font-bold text-[#fafafa] tracking-tight">MIT</div>
          <div class="text-xs text-[#71717a] mt-0.5">Open License</div>
        </div>
        <div class="h-8 w-px bg-[#27272a] hidden sm:block"></div>
        <div class="text-center">
          <div class="text-2xl font-bold text-[#fafafa] tracking-tight">100%</div>
          <div class="text-xs text-[#71717a] mt-0.5">Transparent Finances</div>
        </div>
        <div class="h-8 w-px bg-[#27272a] hidden sm:block"></div>
        <div class="text-center">
          <div class="text-2xl font-bold text-[#fafafa] tracking-tight">🇮🇩</div>
          <div class="text-xs text-[#71717a] mt-0.5">Indonesia-based</div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY FUND US -->
  <section id="impact" class="border-y border-[#27272a] bg-[#0f0f11] px-4 sm:px-6 py-12 sm:py-20 scroll-mt-14">
    <div class="mx-auto max-w-6xl">
      <div class="mb-10 sm:mb-14 text-center">
        <div class="mb-3 inline-flex items-center gap-2 rounded-full border border-[#27272a] bg-[#18181b] px-3 py-1 text-xs text-[#71717a]">
          Why Fund Us
        </div>
        <h2 class="mb-3 text-2xl sm:text-3xl lg:text-4xl font-bold tracking-tight text-[#fafafa]">The problem we are solving</h2>
        <p class="mx-auto max-w-xl text-[#a1a1aa] text-sm sm:text-base leading-relaxed">
          Indonesia has 277 million people, 45 million students, and a fast-growing AI sector —
          but almost no open-source AI tooling built for its context.
        </p>
      </div>

      <!-- Impact cards: 1 col → 2 col (sm) → 3 col (lg) -->
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 mb-8 sm:mb-10">
        <div class="rounded-2xl border border-[#27272a] bg-[#18181b] p-6">
          <div class="mb-4 text-3xl font-bold text-[#a78bfa]">45M+</div>
          <h4 class="mb-2 text-sm font-semibold text-[#fafafa]">Students in Indonesia</h4>
          <p class="text-xs text-[#71717a] leading-relaxed">
            Lack access to AI-powered career guidance and mental health support tools designed
            for their language, culture, and economic context.
          </p>
        </div>
        <div class="rounded-2xl border border-[#27272a] bg-[#18181b] p-6">
          <div class="mb-4 text-3xl font-bold text-[#fbbf24]">0</div>
          <h4 class="mb-2 text-sm font-semibold text-[#fafafa]">Critical-thinking AI tools</h4>
          <p class="text-xs text-[#71717a] leading-relaxed">
            Mainstream AI tools breed dependency. No open-source middleware exists that
            actively teaches Socratic thinking before providing answers.
          </p>
        </div>
        <div class="rounded-2xl border border-[#27272a] bg-[#18181b] p-6 sm:col-span-2 lg:col-span-1">
          <div class="mb-4 text-3xl font-bold text-[#34d399]">$0</div>
          <h4 class="mb-2 text-sm font-semibold text-[#fafafa]">External funding received</h4>
          <p class="text-xs text-[#71717a] leading-relaxed">
            Everything built so far is self-funded and volunteer-driven. Funding unlocks
            full-time development, research, and community outreach.
          </p>
        </div>
      </div>

      <!-- What funding unlocks: 1 → 2 (sm) → 4 (lg) -->
      <div class="rounded-2xl border border-[#8b5cf6]/20 bg-[#8b5cf6]/5 p-6 sm:p-8">
        <h3 class="mb-5 sm:mb-6 text-sm sm:text-base font-semibold text-[#fafafa]">What your funding unlocks</h3>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {[
            { icon: '⚡', label: 'Full-time dev', desc: 'Move from nights-and-weekends to full-time shipping' },
            { icon: '🏫', label: 'School pilots', desc: 'Run We Will Shine pilots in Indonesian high schools' },
            { icon: '🔬', label: 'Research output', desc: 'Publish findings on AI & critical thinking in EdTech' },
            { icon: '🌐', label: 'Community', desc: 'Grow a local open-source AI developer community' },
          ].map(item => (
            <div class="flex gap-3">
              <div class="mt-0.5 text-xl shrink-0">{item.icon}</div>
              <div>
                <div class="text-sm font-medium text-[#fafafa] mb-1">{item.label}</div>
                <div class="text-xs text-[#71717a] leading-relaxed">{item.desc}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- PROJECTS -->
  <section id="projects" class="px-4 sm:px-6 py-12 sm:py-20 scroll-mt-14">
    <div class="mx-auto max-w-6xl">
      <div class="mb-10 sm:mb-14 text-center">
        <div class="mb-3 inline-flex items-center gap-2 rounded-full border border-[#27272a] bg-[#18181b] px-3 py-1 text-xs text-[#71717a]">
          The Projects
        </div>
        <h2 class="mb-3 text-2xl sm:text-3xl lg:text-4xl font-bold tracking-tight text-[#fafafa]">Four tools, one mission</h2>
        <p class="mx-auto max-w-lg text-[#a1a1aa] text-sm sm:text-base leading-relaxed">
          Making AI development and education more humane, transparent, and accessible.
        </p>
      </div>

      <!-- Project cards: 1 col → 2 col (md) → 4 col (lg) -->
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-4">

        <!-- 2USE — highlighted as primary funding target -->
        <article class="group relative flex flex-col rounded-2xl border border-[#f59e0b]/30 bg-[#0f0f11] p-6 transition-all hover:-translate-y-1 hover:shadow-xl hover:shadow-[#f59e0b]/5">
          <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[#f59e0b]/60 to-transparent rounded-t-2xl"></div>
          <div class="absolute top-4 right-4">
            <span class="rounded-full bg-[#f59e0b]/15 border border-[#f59e0b]/30 px-2 py-0.5 text-[10px] font-semibold text-[#fbbf24] uppercase tracking-wider">Core Focus</span>
          </div>

          <div class="mb-4 flex items-start">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-[#f59e0b] to-[#d97706] shadow-lg shadow-[#f59e0b]/20">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3m.08 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
          </div>

          <h3 class="mb-1 text-base font-semibold text-[#fafafa]">
            2USE
            <span class="ml-1.5 font-mono text-[10px] font-normal text-[#71717a] tracking-wide">/ double-u-es /</span>
          </h3>
          <p class="mb-4 text-sm text-[#71717a] leading-relaxed">
            AI middleware that refuses instant answers. Forces critical thinking through Socratic method before any LLM responds. Anti-dependency by design.
          </p>
          <ul class="mb-6 flex flex-col gap-2 flex-1">
            {[
              'Intercepts AI queries — asks clarifying questions first',
              'Pluggable into any LLM pipeline as middleware',
              'Designed for students, educators, and edtech platforms',
              'Research foundation: Socratic pedagogy + AI alignment',
            ].map(item => (
              <li class="flex items-start gap-2 text-xs text-[#71717a]">
                <svg class="mt-0.5 shrink-0 text-[#f59e0b]" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                {item}
              </li>
            ))}
          </ul>
          <div class="mb-3 rounded-xl bg-[#f59e0b]/8 border border-[#f59e0b]/15 px-4 py-3">
            <p class="text-xs text-[#a1a1aa] leading-relaxed">
              <span class="font-medium text-[#fbbf24]">Research opportunity:</span> 2USE is a novel application of Socratic AI — suitable for EdTech, HCI, and AI Ethics research grants.
            </p>
          </div>
          <a href="https://github.com/ainjiner/2USE" target="_blank" rel="noopener"
             class="flex items-center justify-center gap-2 rounded-xl border border-[#f59e0b]/25 bg-[#18181b] px-4 py-2.5 text-xs font-medium text-[#a1a1aa] hover:border-[#f59e0b]/50 hover:text-[#fbbf24] transition-colors min-h-[44px]">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844a9.59 9.59 0 012.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
            View on GitHub
          </a>
        </article>

        <!-- We Will Shine -->
        <article class="group relative flex flex-col rounded-2xl border border-[#27272a] bg-[#0f0f11] p-6 transition-all hover:-translate-y-1 hover:border-[#10b981]/40 hover:shadow-xl hover:shadow-[#10b981]/5">
          <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[#10b981]/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity rounded-t-2xl"></div>
          <div class="mb-4 flex items-start justify-between">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-[#10b981] to-[#059669] shadow-lg shadow-[#10b981]/20">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <span class="rounded-full border border-[#10b981]/20 bg-[#10b981]/10 px-2 py-0.5 text-[10px] font-medium text-[#34d399]">Live</span>
          </div>
          <h3 class="mb-1 text-base font-semibold text-[#fafafa]">
            We Will Shine
            <span class="ml-1.5 font-mono text-[10px] font-normal text-[#71717a] tracking-wide">/ W·S /</span>
          </h3>
          <p class="mb-4 text-sm text-[#71717a] leading-relaxed">
            AI-powered career guidance and student wellbeing platform for Indonesian students and school counselors (Guru BK).
          </p>
          <ul class="mb-6 flex flex-col gap-2 flex-1">
            {[
              'AI career guidance in Bahasa Indonesia',
              'Safe anonymous journaling & counseling space',
              'Counselor dashboard with wellbeing insights',
              'Built with SvelteKit — fully open source & MIT licensed',
            ].map(item => (
              <li class="flex items-start gap-2 text-xs text-[#71717a]">
                <svg class="mt-0.5 shrink-0 text-[#10b981]" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                {item}
              </li>
            ))}
          </ul>
          <div class="flex gap-2">
            <a href="https://github.com/ainjiner/we-will-shine" target="_blank" rel="noopener"
               class="flex flex-1 items-center justify-center gap-2 rounded-xl border border-[#27272a] bg-[#18181b] px-4 py-2.5 text-xs font-medium text-[#a1a1aa] hover:border-[#10b981]/40 hover:text-[#34d399] transition-colors min-h-[44px]">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844a9.59 9.59 0 012.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
              GitHub
            </a>
            <a href="https://ainjiner.github.io/we-will-shine/" target="_blank" rel="noopener"
               class="flex items-center justify-center gap-1.5 rounded-xl border border-[#10b981]/25 bg-[#10b981]/10 px-4 py-2.5 text-xs font-medium text-[#34d399] hover:bg-[#10b981]/20 transition-colors min-h-[44px]">
              Live Demo
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/></svg>
            </a>
          </div>
        </article>

        <!-- AI Lab -->
        <article class="group relative flex flex-col rounded-2xl border border-[#27272a] bg-[#0f0f11] p-6 transition-all hover:-translate-y-1 hover:border-[#8b5cf6]/40 hover:shadow-xl hover:shadow-[#8b5cf6]/5">
          <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[#8b5cf6]/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity rounded-t-2xl"></div>
          <div class="mb-4 flex items-start justify-between">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-[#8b5cf6] to-[#6d28d9] shadow-lg shadow-[#8b5cf6]/20">
