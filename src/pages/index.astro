---
import Base from '../layouts/Base.astro';
import '../styles/global.css';
---

<Base>
  <!-- NAV -->
  <header class="sticky top-0 z-50 border-b border-[#27272a] bg-[#09090b]/80 backdrop-blur-xl">
    <div class="mx-auto max-w-6xl px-6 h-14 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5 font-semibold text-sm tracking-tight">
        <svg width="26" height="26" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="64" height="64" rx="14" fill="#8b5cf6"/>
          <text x="32" y="45" font-family="Georgia,serif" font-size="36" font-weight="700" fill="white" text-anchor="middle">A</text>
        </svg>
        <span class="text-[#fafafa]">ainjiner</span>
      </a>
      <nav class="flex items-center gap-1">
        <a href="#projects" class="px-3 py-1.5 text-sm text-[#a1a1aa] hover:text-[#fafafa] rounded-md hover:bg-[#18181b] transition-colors">Projects</a>
        <a href="#mission" class="px-3 py-1.5 text-sm text-[#a1a1aa] hover:text-[#fafafa] rounded-md hover:bg-[#18181b] transition-colors hidden sm:inline-flex">Mission</a>
        <a href="#support" class="px-3 py-1.5 text-sm text-[#a1a1aa] hover:text-[#fafafa] rounded-md hover:bg-[#18181b] transition-colors">Support</a>
        <a
          href="https://github.com/ainjiner"
          target="_blank"
          rel="noopener"
          class="ml-2 flex items-center gap-1.5 px-3 py-1.5 text-sm text-[#fafafa] bg-[#18181b] border border-[#27272a] rounded-lg hover:border-[#3f3f46] transition-colors"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844a9.59 9.59 0 012.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
          GitHub
        </a>
      </nav>
    </div>
  </header>

  <!-- HERO -->
  <section class="relative overflow-hidden px-6 pt-24 pb-20 text-center">
    <!-- subtle radial glow -->
    <div class="pointer-events-none absolute inset-0 flex items-start justify-center">
      <div class="mt-[-60px] h-[480px] w-[800px] rounded-full bg-[#8b5cf6]/10 blur-[120px]"></div>
    </div>
    <!-- grid dots bg -->
    <div class="pointer-events-none absolute inset-0 opacity-[0.03]"
      style="background-image: radial-gradient(#fafafa 1px, transparent 1px); background-size: 32px 32px;"></div>

    <div class="relative mx-auto max-w-3xl">
      <!-- badge -->
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#8b5cf6]/25 bg-[#8b5cf6]/10 px-3.5 py-1 text-xs font-medium text-[#a78bfa]">
        <span class="h-1.5 w-1.5 rounded-full bg-[#a78bfa] animate-pulse"></span>
        Open Source · Indonesia 🇮🇩
      </div>

      <h1 class="mb-5 text-4xl font-bold tracking-tight text-[#fafafa] sm:text-5xl md:text-6xl leading-[1.08]">
        Building tools for<br />
        <span class="bg-gradient-to-br from-[#a78bfa] via-[#818cf8] to-[#60a5fa] bg-clip-text text-transparent">
          AI/ML developers
        </span>
      </h1>

      <p class="mx-auto mb-9 max-w-xl text-base text-[#a1a1aa] leading-relaxed sm:text-lg">
        Ainjiner is an open-source engineering organization creating tools that empower developers
        to build, manage, and deploy AI systems — without the lock-in.
      </p>

      <div class="flex flex-wrap items-center justify-center gap-3 mb-14">
        <a
          href="#projects"
          class="inline-flex items-center gap-2 rounded-xl bg-[#8b5cf6] px-5 py-2.5 text-sm font-medium text-white shadow-lg shadow-[#8b5cf6]/25 hover:bg-[#7c3aed] transition-all hover:-translate-y-px"
        >
          Explore Projects
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a
          href="#support"
          class="inline-flex items-center gap-2 rounded-xl border border-[#27272a] bg-[#18181b] px-5 py-2.5 text-sm font-medium text-[#a1a1aa] hover:text-[#fafafa] hover:border-[#3f3f46] transition-all hover:-translate-y-px"
        >
          Support Our Work
        </a>
      </div>

      <!-- stats -->
      <div class="flex items-center justify-center gap-8 flex-wrap">
        <div class="text-center">
          <div class="text-2xl font-bold text-[#fafafa] tracking-tight">3</div>
          <div class="text-xs text-[#71717a] mt-0.5">Open Source Projects</div>
        </div>
        <div class="h-8 w-px bg-[#27272a] hidden sm:block"></div>
        <div class="text-center">
          <div class="text-2xl font-bold text-[#fafafa] tracking-tight">MIT</div>
          <div class="text-xs text-[#71717a] mt-0.5">Licensed</div>
        </div>
        <div class="h-8 w-px bg-[#27272a] hidden sm:block"></div>
        <div class="text-center">
          <div class="text-2xl font-bold text-[#fafafa] tracking-tight">∞</div>
          <div class="text-xs text-[#71717a] mt-0.5">Community Driven</div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROJECTS -->
  <section id="projects" class="px-6 py-20">
    <div class="mx-auto max-w-6xl">
      <div class="mb-14 text-center">
        <h2 class="mb-3 text-3xl font-bold tracking-tight text-[#fafafa] sm:text-4xl">Our Projects</h2>
        <p class="mx-auto max-w-lg text-[#a1a1aa] text-base leading-relaxed">
          Three tools, one mission — making AI development more humane, transparent, and accessible.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-4 md:grid-cols-3">

        <!-- AI Lab -->
        <article class="group relative flex flex-col rounded-2xl border border-[#27272a] bg-[#0f0f11] p-6 transition-all hover:-translate-y-1 hover:border-[#8b5cf6]/40 hover:shadow-xl hover:shadow-[#8b5cf6]/5">
          <!-- top glow on hover -->
          <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[#8b5cf6]/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity rounded-t-2xl"></div>

          <div class="mb-4 flex items-start justify-between">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-[#8b5cf6] to-[#6d28d9] shadow-lg shadow-[#8b5cf6]/20">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M9.663 17h4.673M12 3v1m6.364 1.636-.707.707M21 12h-1M4 12H3m3.343-5.657-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
            </div>
            <div class="flex gap-1.5">
              <span class="rounded-full border border-[#8b5cf6]/20 bg-[#8b5cf6]/10 px-2 py-0.5 text-[10px] font-medium text-[#a78bfa]">ML/LLM</span>
              <span class="rounded-full border border-[#8b5cf6]/20 bg-[#8b5cf6]/10 px-2 py-0.5 text-[10px] font-medium text-[#a78bfa]">Platform</span>
            </div>
          </div>

          <h3 class="mb-2 text-base font-semibold text-[#fafafa]">AI Lab</h3>
          <p class="mb-4 text-sm text-[#71717a] leading-relaxed">
            ML/LLM Engineering Platform. Unified provider registry, model catalog, experiment tracking, and cost analytics with OpenCode-native config sync.
          </p>

          <ul class="mb-6 flex flex-col gap-1.5 flex-1">
            {[
              '10 built-in providers (OpenAI, Anthropic, Gemini…)',
              'Experiment tracking + cost analytics',
              'Config sync to OpenCode, Cursor, Continue',
              'REST API + CLI + Web UI — self-hosted',
            ].map(item => (
              <li class="flex items-start gap-2 text-xs text-[#71717a]">
                <svg class="mt-0.5 shrink-0 text-[#8b5cf6]" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                {item}
              </li>
            ))}
          </ul>

          <a
            href="https://github.com/ainjiner/ai-lab"
            target="_blank"
            rel="noopener"
            class="flex items-center justify-center gap-2 rounded-xl border border-[#27272a] bg-[#18181b] px-4 py-2.5 text-xs font-medium text-[#a1a1aa] hover:border-[#8b5cf6]/40 hover:text-[#a78bfa] transition-colors"
          >
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844a9.59 9.59 0 012.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
            View on GitHub
          </a>
        </article>

        <!-- 2USE -->
        <article class="group relative flex flex-col rounded-2xl border border-[#27272a] bg-[#0f0f11] p-6 transition-all hover:-translate-y-1 hover:border-[#f59e0b]/40 hover:shadow-xl hover:shadow-[#f59e0b]/5">
          <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[#f59e0b]/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity rounded-t-2xl"></div>

          <div class="mb-4 flex items-start justify-between">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-[#f59e0b] to-[#d97706] shadow-lg shadow-[#f59e0b]/20">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3m.08 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div class="flex gap-1.5">
              <span class="rounded-full border border-[#f59e0b]/20 bg-[#f59e0b]/10 px-2 py-0.5 text-[10px] font-medium text-[#fbbf24]">EdTech</span>
              <span class="rounded-full border border-[#f59e0b]/20 bg-[#f59e0b]/10 px-2 py-0.5 text-[10px] font-medium text-[#fbbf24]">Middleware</span>
            </div>
          </div>

          <h3 class="mb-1 text-base font-semibold text-[#fafafa]">
            2USE
            <span class="ml-1.5 font-mono text-[10px] font-normal text-[#71717a] tracking-wide">/ double-u-es /</span>
          </h3>
          <p class="mb-4 text-sm text-[#71717a] leading-relaxed">
            AI middleware that refuses instant answers. Teaches critical thinking through Socratic method. Anti-dependency by design.
          </p>

          <ul class="mb-6 flex flex-col gap-1.5 flex-1">
            {[
              'Intercepts queries, responds with questions first',
              'Forces deeper engagement before answering',
              'Pluggable into any LLM pipeline as middleware',
              'Designed for students and educators',
            ].map(item => (
              <li class="flex items-start gap-2 text-xs text-[#71717a]">
                <svg class="mt-0.5 shrink-0 text-[#f59e0b]" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                {item}
              </li>
            ))}
          </ul>

          <a
            href="https://github.com/ainjiner/2USE"
            target="_blank"
            rel="noopener"
            class="flex items-center justify-center gap-2 rounded-xl border border-[#27272a] bg-[#18181b] px-4 py-2.5 text-xs font-medium text-[#a1a1aa] hover:border-[#f59e0b]/40 hover:text-[#fbbf24] transition-colors"
          >
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844a9.59 9.59 0 012.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
            View on GitHub
          </a>
        </article>

        <!-- We Will Shine -->
        <article class="group relative flex flex-col rounded-2xl border border-[#27272a] bg-[#0f0f11] p-6 transition-all hover:-translate-y-1 hover:border-[#10b981]/40 hover:shadow-xl hover:shadow-[#10b981]/5">
          <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[#10b981]/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity rounded-t-2xl"></div>

          <div class="mb-4 flex items-start justify-between">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-[#10b981] to-[#059669] shadow-lg shadow-[#10b981]/20">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <div class="flex gap-1.5">
              <span class="rounded-full border border-[#10b981]/20 bg-[#10b981]/10 px-2 py-0.5 text-[10px] font-medium text-[#34d399]">Education</span>
              <span class="rounded-full border border-[#10b981]/20 bg-[#10b981]/10 px-2 py-0.5 text-[10px] font-medium text-[#34d399]">Indonesia</span>
            </div>
          </div>

          <h3 class="mb-1 text-base font-semibold text-[#fafafa]">
            We Will Shine
            <span class="ml-1.5 font-mono text-[10px] font-normal text-[#71717a] tracking-wide">/ W·S /</span>
          </h3>
          <p class="mb-4 text-sm text-[#71717a] leading-relaxed">
            Open-source platform for career guidance & student wellbeing with an AI mentor for Indonesian students and school counselors.
          </p>

          <ul class="mb-6 flex flex-col gap-1.5 flex-1">
            {[
              'AI-powered career guidance for students',
              'Safe, anonymous counseling & journaling',
              'Dashboard for school counselors (Guru BK)',
              'Built with SvelteKit + Tailwind, MIT licensed',
            ].map(item => (
              <li class="flex items-start gap-2 text-xs text-[#71717a]">
                <svg class="mt-0.5 shrink-0 text-[#10b981]" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                {item}
              </li>
            ))}
          </ul>

          <div class="flex gap-2">
            <a
              href="https://github.com/ainjiner/we-will-shine"
              target="_blank"
              rel="noopener"
              class="flex flex-1 items-center justify-center gap-2 rounded-xl border border-[#27272a] bg-[#18181b] px-4 py-2.5 text-xs font-medium text-[#a1a1aa] hover:border-[#10b981]/40 hover:text-[#34d399] transition-colors"
            >
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844a9.59 9.59 0 012.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
              GitHub
            </a>
            <a
              href="https://ainjiner.github.io/we-will-shine/"
              target="_blank"
              rel="noopener"
              class="flex items-center justify-center gap-1.5 rounded-xl border border-[#10b981]/25 bg-[#10b981]/10 px-4 py-2.5 text-xs font-medium text-[#34d399] hover:bg-[#10b981]/20 transition-colors"
            >
              Live
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/></svg>
            </a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- MISSION -->
  <section id="mission" class="border-y border-[#27272a] bg-[#0f0f11] px-6 py-20">
    <div class="mx-auto max-w-6xl">
      <div class="mb-14 text-center">
        <h2 class="mb-3 text-3xl font-bold tracking-tight text-[#fafafa] sm:text-4xl">Our Mission</h2>
        <p class="mx-auto max-w-md text-[#a1a1aa] text-base leading-relaxed">
          Why we build what we build.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { icon: '🌍', title: 'Democratize AI Tools', desc: 'Make ML/LLM engineering accessible to every developer — not just those at large companies with big budgets.' },
          { icon: '🔓', title: 'Open Source First', desc: 'All tools are MIT licensed and community-driven. No paywalls, no vendor lock-in, no hidden agendas.' },
          { icon: '🧠', title: 'Teach, Don\'t Depend', desc: 'AI should augment human thinking, not replace it. Our tools are designed to foster independent thought.' },
          { icon: '🇮🇩', title: 'Built in Indonesia', desc: 'Proudly built by Indonesian developers, with love for the local education and tech ecosystem.' },
        ].map(item => (
          <div class="rounded-2xl border border-[#27272a] bg-[#18181b] p-5">
            <div class="mb-3 text-2xl">{item.icon}</div>
            <h4 class="mb-2 text-sm font-semibold text-[#fafafa]">{item.title}</h4>
            <p class="text-xs text-[#71717a] leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SUPPORT / FUNDING -->
  <section id="support" class="px-6 py-20">
    <div class="mx-auto max-w-6xl">
      <div class="mb-14 text-center">
        <h2 class="mb-3 text-3xl font-bold tracking-tight text-[#fafafa] sm:text-4xl">Support Our Work</h2>
        <p class="mx-auto max-w-lg text-[#a1a1aa] text-base leading-relaxed">
          All three projects are free and open source. Your support directly funds development and infrastructure.
          Every contribution — big or small — matters.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4 mb-8">

        <!-- GitHub Sponsors -->
        <a
          href="https://github.com/sponsors/ainjiner"
          target="_blank"
          rel="noopener"
          class="group flex flex-col gap-4 rounded-2xl border border-[#27272a] bg-[#0f0f11] p-6 transition-all hover:-translate-y-1 hover:border-[#ec4899]/40 hover:shadow-lg hover:shadow-[#ec4899]/5"
        >
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-[#ec4899]/10 border border-[#ec4899]/20 text-[#ec4899]">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.593c-.425-.636-8.208-6.048-8.208-10.593 0-4.208 3.584-6 7.208-6 3.624 0 7.208 1.792 7.208 6C18.208 15.545 12.425 20.957 12 21.593z"/></svg>
          </div>
          <div class="flex-1">
            <h4 class="mb-1.5 text-sm font-semibold text-[#fafafa]">GitHub Sponsors</h4>
            <p class="text-xs text-[#71717a] leading-relaxed">Recurring or one-time. Your name appears on our repos as a sponsor.</p>
          </div>
          <span class="flex items-center gap-1 text-xs font-medium text-[#ec4899] group-hover:gap-2 transition-all">
            Sponsor on GitHub
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </a>

        <!-- Open Collective -->
        <a
